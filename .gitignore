# ────────────────────────────
#  Node & package managers
# ────────────────────────────
node_modules/
package-lock.json
npm-debug.log*
pnpm-lock.yaml
yarn.lock

# ────────────────────────────
#  Next.js build output
# ────────────────────────────
.next/
.next/cache/
out/
dist/

# ────────────────────────────
#  Logs
# ────────────────────────────
logs/
*.log
*.tsbuildinfo

# ────────────────────────────
#  Editor / IDE settings
# ────────────────────────────
.vscode/
*.code-workspace
.idea/
.claude/

# ────────────────────────────
#  OS / system files
# ────────────────────────────
.DS_Store
Thumbs.db

# ────────────────────────────
#  Environment variables
# ────────────────────────────
.env
.env.local
.env.*.local

# ────────────────────────────
#  Python
# ────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ────────────────────────────
#  Generated reports (build artifacts)
# ────────────────────────────
# Generated by npm run inventory:ksas, audit_horizons, etc.
# Manual audit narratives (audit_completion_report_*.md) are preserved.
reports/
!reports/audit_completion_report_*.md

# ────────────────────────────
#  Misc
# ────────────────────────────
*.swp
*.swo
coverage/
node_modules
